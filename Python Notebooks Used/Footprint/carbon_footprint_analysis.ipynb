   "source": [
    "# Carbon Footprint Visualizer (Python Implementation)\n",
    "\n",
    "This notebook replicates the \"Foot-Shaped\" carbon footprint visualization built in the web app. It uses **Pandas** for data processing and **Plotly** for interactive visualization.\n",
    "\n",
    "### 1. Install Dependencies\n",
    "Uncomment the line below if you need to install the required libraries."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# !pip install pandas plotly numpy"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 2. Import Libraries and Fetch Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import plotly.graph_objects as go\n",
    "from plotly.subplots import make_subplots\n",
    "\n",
    "# Load live data from Our World in Data\n",
    "DATA_URL = \"https://raw.githubusercontent.com/owid/co2-data/master/owid-co2-data.csv\"\n",
    "df = pd.read_csv(DATA_URL)\n",
    "\n",
    "# Filter for relevant years and valid countries\n",
    "df = df[(df['year'] >= 2007) & (df['year'] <= 2023) & df['iso_code'].notna()]\n",
    "df = df[['country', 'year', 'co2', 'co2_per_capita', 'continent']]\n",
    "\n",
    "print(f\"Loaded {len(df)} records.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3. The Foot Layout Algorithm\n",
    "This function calculates the (x, y) coordinates for each country to form the foot shape."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_foot_layout(data, value_key, x_offset, is_left=True):\n",
    "    \"\"\"\n",
    "    Calculates coordinates to arrange bubbles into a foot shape.\n",
    "    \"\"\"\n",
    "    sorted_df = data.sort_values(by=value_key, ascending=False).head(100)\n",
    "    toes = sorted_df.head(5)\n",
    "    sole = sorted_df.iloc[5:]\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    # 1. Arrange Toes\n",
    "    toe_offsets = [\n",
    "        {'x': 0.5, 'y': 1.35}, {'x': 0.15, 'y': 1.5}, \n",
    "        {'x': -0.15, 'y': 1.55}, {'x': -0.4, 'y': 1.5}, {'x': -0.6, 'y': 1.4}\n",
    "    ]\n",
    "    if not is_left:\n",
    "        for o in toe_offsets: o['x'] = -o['x']\n",
    "        \n",
    "    for i, (_, row) in enumerate(toes.iterrows()):\n",
    "        results.append({\n",
    "            'country': row['country'],\n",
    "            'x': toe_offsets[i]['x'] + x_offset,\n",
    "            'y': toe_offsets[i]['y'] * 1.6,\n",
    "            'size': np.sqrt(row[value_key]) * (2.5 if value_key == 'co2' else 45),\n",
    "            'continent': row['continent']\n",
    "        })\n",
    "        \n",
    "    # 2. Arrange Sole (Simplified packing using a spiral for Python implementation)\n",
    "    for i, (_, row) in enumerate(sole.iterrows()):\n",
    "        t = i / len(sole)\n",
    "        # Create an elongated elliptical shape for the sole\n",
    "        angle = i * 0.5\n",
    "        radius = np.sqrt(i) * 0.1\n",
    "        \n",
    "        # Apply foot-specific scaling\n",
    "        y = (t - 0.5) * 2.5\n",
    "        width = 0.6 * np.exp(-(y - 0.1)**2 / 0.5) + 0.4\n",
    "        x = np.sin(angle) * radius * width\n",
    "        \n",
    "        # Arch curve\n",
    "        arch = np.sin(t * np.pi) * 0.3\n",
    "        medial_shift = -arch if is_left else arch\n",
    "        \n",
    "        results.append({\n",
    "            'country': row['country'],\n",
    "            'x': x + x_offset + medial_shift,\n",
    "            'y': y,\n",
    "            'size': np.sqrt(row[value_key]) * (1.5 if value_key == 'co2' else 30),\n",
    "            'continent': row['continent']\n",
    "        })\n",
    "        \n",
    "    return pd.DataFrame(results)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 4. Generate Interactive Visualization\n",
    "We create a Plotly figure with a slider to navigate through the years."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig = go.Figure()\n",
    "\n",
    "years = sorted(df['year'].unique())\n",
    "continents = df['continent'].unique()\n",
    "colors = {'Asia': '#f97316', 'Europe': '#16a34a', 'North America': '#a3e635', \n",
    "          'South America': '#92400e', 'Africa': '#9333ea', 'Oceania': '#1d4ed8'}\n",
    "\n",
    "for year in years:\n",
    "    year_df = df[df['year'] == year]\n",
    "    \n",
    "    # Calculate layouts\n",
    "    left_foot = get_foot_layout(year_df, 'co2', -1.5, is_left=True)\n",
    "    right_foot = get_foot_layout(year_df, 'co2_per_capita', 1.5, is_left=False)\n",
    "    \n",
    "    # Add Left Foot (Total Emissions)\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=left_foot['x'], y=left_foot['y'],\n",
    "        mode='markers',\n",
    "        name=f'Total {year}',\n",
    "        visible=(year == 2022),\n",
    "        marker=dict(\n",
    "            size=left_foot['size'],\n",
    "            color=[colors.get(c, '#666') for c in left_foot['continent']],\n",
    "            opacity=0.8,\n",
    "            line=dict(width=0.5, color='white')\n",
    "        ),\n",
    "        text=left_foot['country'],\n",
    "        hoverinfo='text'\n",
    "    ))\n",
    "    \n",
    "    # Add Right Foot (Per Capita)\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=right_foot['x'], y=right_foot['y'],\n",
    "        mode='markers',\n",
    "        name=f'Per Capita {year}',\n",
    "        visible=(year == 2022),\n",
    "        marker=dict(\n",
    "            size=right_foot['size'],\n",
    "            color=[colors.get(c, '#666') for c in right_foot['continent']],\n",
    "            opacity=0.8,\n",
    "            line=dict(width=0.5, color='white')\n",
    "        ),\n",
    "        text=right_foot['country'],\n",
    "        hoverinfo='text'\n",
    "    ))\n",
    "\n",
    "# Create Slider\n",
    "steps = []\n",
    "for i, year in enumerate(years):\n",
    "    step = dict(\n",
    "        method=\"update\",\n",
    "        args=[{\"visible\": [False] * len(fig.data)}],\n",
    "        label=str(year)\n",
    "    )\n",
    "    step[\"args\"][0][\"visible\"][i*2] = True\n",
    "    step[\"args\"][0][\"visible\"][i*2 + 1] = True\n",
    "    steps.append(step)\n",
    "\n",
    "sliders = [dict(\n",
    "    active=15, # Default to 2022\n",
    "    currentvalue={\"prefix\": \"Year: \", \"font\": {\"size\": 20, \"color\": \"#3b82f6\"}},\n",
    "    pad={\"t\": 50},\n",
    "    steps=steps\n",
    ")]\n",
    "\n",
    "fig.update_layout(\n",
    "    sliders=sliders,\n",
    "    template=\"plotly_dark\",\n",
    "    showlegend=False,\n",
    "    xaxis=dict(visible=False, range=[-4, 4]),\n",
    "    yaxis=dict(visible=False, range=[-3, 3]),\n",
    "    margin=dict(l=0, r=0, t: 50, b=0),\n",
    "    height=800,\n",
    "    annotations=[\n",
    "        dict(x=-1.5, y=2.8, text=\"TOTAL EMISSIONS (Mt)\", showarrow=False, font=dict(size=12, color=\"gray\")),\n",
    "        dict(x=1.5, y=2.8, text=\"PER CAPITA (t)\", showarrow=False, font=dict(size=12, color=\"gray\"))\n",
    "    ]\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
  }\n",
 ],\n",
